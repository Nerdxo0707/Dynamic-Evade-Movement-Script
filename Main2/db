local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")

local Player = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local CHARACTER = Player.Character or Player.CharacterAdded:Wait()
local Humanoid = CHARACTER:WaitForChild("Humanoid")
local RootPart = CHARACTER:WaitForChild("HumanoidRootPart")
local playerGui = Player:WaitForChild("PlayerGui")

-- MOVEMENT CONFIGS (DO NOT TOUCH UNLESS YOU HAVE THE 200 IQ)
local WALL_RUN_SPEED = 50        -- buddy is zoomin
local WALL_JUMP_POWER = 90       -- full send off the wall
local WALL_CHECK_DISTANCE = 4    -- checking if the wall is a real one
local MAX_WALL_RUN_TIME = 2.5    -- wall running has a time limit, no camping
local ACCELERATION = 2.5

-- YOUR CUSTOM CAMERA VALUES
local BASE_FOV = 70
local MAX_FOV = 82
local FOV_SMOOTHNESS = 0.1

local TILT_AMOUNT = 5
local SWAY_SPEED = 10
local SWAY_AMOUNT = 0.10

-- WALL RUN EXTRA CAMERA TWIST
local WALL_RUN_TILT = 14          -- leaning into the wall run hits different

-- STATE VARIABLES (LET THEM COOK)
local wallRunning = false
local wallRunStart = 0
local currentWallNormal = nil
local currentWallSide = nil
local currentSpeed = 0

local wallJumping = false
local wallJumpCooldown = false

local currentTilt = 0
local swayTime = 0

Camera.FieldOfView = BASE_FOV

-- --- PRESET MONOCHROME GRADIENTS (CLEAN FR) ---
local textGradientSequence = ColorSequence.new({
	ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 255)), -- Pure crisp white at the top
	ColorSequenceKeypoint.new(1, Color3.fromRGB(160, 160, 160))  -- Clean silver-gray at the bottom
})

local bgGradientSequence = ColorSequence.new({
	ColorSequenceKeypoint.new(0, Color3.fromRGB(40, 40, 40)),    -- Dark charcoal top
	ColorSequenceKeypoint.new(1, Color3.fromRGB(15, 15, 15))     -- Near pitch-black bottom
})

-- --- THE ARIMO + MONOCHROME GRADIENT OVERLORD SYSTEM ---
local function forceGradientAndArimo(object)
	-- Check if the object is an actual text container
	if object:IsA("TextLabel") or object:IsA("TextButton") or object:IsA("TextBox") then
		object.Font = Enum.Font.Arimo
		object.TextColor3 = Color3.new(1, 1, 1) -- Set base to white so gradient renders perfectly
		
		-- Slap a text gradient on it if it doesn't already have one
		if not object:FindFirstChildOfClass("UIGradient") then
			local textGrad = Instance.new("UIGradient")
			textGrad.Color = textGradientSequence
			textGrad.Rotation = 90 -- Vertical fade
			textGrad.Parent = object
		end
		
		-- If it has a solid background, give it that dark metallic gradient vibe
		if object.BackgroundTransparency < 1 inside object then
			object.BackgroundColor3 = Color3.new(1, 1, 1) -- Reset base color for background gradient mapping
			local bgGrad = Instance.new("UIGradient")
			bgGrad.Color = bgGradientSequence
			bgGrad.Rotation = 90
			bgGrad.Parent = object
		end
	end
	
	-- Handle standalone frames/background menus to keep everything unified
	if object:IsA("Frame") or object:IsA("ScrollingFrame") then
		if object.BackgroundTransparency < 1 and not object:FindFirstChildOfClass("UIGradient") then
			object.BackgroundColor3 = Color3.new(1, 1, 1)
			local frameGrad = Instance.new("UIGradient")
			frameGrad.Color = bgGradientSequence
			frameGrad.Rotation = 90
			frameGrad.Parent = object
		end
	end
	
	-- Keep borders completely dark and high contrast
	if object:IsA("UIStroke") then
		object.Color = Color3.fromRGB(20, 20, 20)
	end
end

-- Process everything currently on screen
for _, descendant in ipairs(playerGui:GetDescendants()) do
	forceGradientAndArimo(descendant)
end

-- Process any new UI clones instantly
playerGui.DescendantAdded:Connect(function(descendant)
	forceGradientAndArimo(descendant)
end)
