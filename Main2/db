local function CharacterAdded(char)
	CHARACTER = char
	Humanoid = char:WaitForChild("Humanoid")
	RootPart = char:WaitForChild("HumanoidRootPart")
	
	wallRunning = false
	wallJumping = false
	currentSpeed = 0
	currentTilt = 0
	swayTime = 0
end

Player.CharacterAdded:Connect(CharacterAdded)

local function getWall()
	if not RootPart then
		return nil
	end

	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.FilterDescendantsInstances = {CHARACTER}

	local rightRay = workspace:Raycast(RootPart.Position, RootPart.CFrame.RightVector * WALL_CHECK_DISTANCE, params)
	if rightRay then return rightRay, "Right" end

	local leftRay = workspace:Raycast(RootPart.Position, -RootPart.CFrame.RightVector * WALL_CHECK_DISTANCE, params)
	if leftRay then return leftRay, "Left" end

	return nil
end

local function stopWallRun()
	wallRunning = false
	currentWallNormal = nil
	currentWallSide = nil
end

local function startWallRun(hit, side)
	if wallRunning or wallJumping then
		return
	end

	wallRunning = true
	wallRunStart = tick()
	currentWallNormal = hit.Normal
	currentWallSide = side
	currentSpeed = math.max(currentSpeed, 15)
end

UserInputService.JumpRequest:Connect(function()
	if not wallRunning or wallJumpCooldown or not currentWallNormal or not RootPart then
		return -- clear skill issue
	end

	wallJumpCooldown = true
	wallJumping = true

	local jumpVelocity = (currentWallNormal * WALL_JUMP_POWER) + Vector3.new(0, 55, 0)
	RootPart.AssemblyLinearVelocity = jumpVelocity

	stopWallRun()

	task.delay(0.3, function() wallJumping = false end)
	task.delay(0.25, function() wallJumpCooldown = false end)
end)

RunService.Heartbeat:Connect(function(dt)
	if not Humanoid or not RootPart then
		return
	end

	if not wallJumping and Humanoid.FloorMaterial == Enum.Material.Air then
		local wall, side = getWall()
		if wall then
			if not wallRunning then startWallRun(wall, side) else currentWallNormal = wall.Normal; currentWallSide = side end
		else
			stopWallRun()
		end
	else
		if not wallJumping then stopWallRun() end
	end

	if wallRunning then
		if tick() - wallRunStart > MAX_WALL_RUN_TIME then
			stopWallRun() -- fell off + ratio
			return
		end

		local wallDirection = currentWallNormal:Cross(Vector3.new(0, 1, 0))
		local moveDir = Humanoid.MoveDirection

		if moveDir.Magnitude > 0 and moveDir:Dot(wallDirection) < 0 then
			wallDirection = -wallDirection
		end

		currentSpeed = math.min(currentSpeed + (ACCELERATION * 60 * dt), WALL_RUN_SPEED)
		local currentVelocity = RootPart.AssemblyLinearVelocity

		RootPart.AssemblyLinearVelocity = Vector3.new(
			wallDirection.X * currentSpeed,
			math.max(currentVelocity.Y, -2),
			wallDirection.Z * currentSpeed
		)
	else
		currentSpeed *= 0.96
	end
end)

-- --- YOUR UPGRADED RENDER LOOP SYSTEM ---
RunService.RenderStepped:Connect(function(dt)
	if not CHARACTER or not Humanoid or not RootPart then
		return
	end

	local moveDirection = Humanoid.MoveDirection
	local velocity = RootPart.AssemblyLinearVelocity
	local speed = Vector3.new(velocity.X, 0, velocity.Z).Magnitude

	-- Dynamic FOV
	local targetFOV = BASE_FOV + math.clamp(speed / 2, 0, MAX_FOV - BASE_FOV)
	Camera.FieldOfView += (targetFOV - Camera.FieldOfView) * FOV_SMOOTHNESS

	-- Strafing Tilt Calculation
	local rightVector = RootPart.CFrame.RightVector
	local sideMovement = moveDirection:Dot(rightVector)

	-- Base tilt from your strafe script
	local targetTilt = -sideMovement * TILT_AMOUNT
	
	-- Inject extra structural tilt if we are running on a wall fr
	if wallRunning then
		if currentWallSide == "Right" then
			targetTilt = WALL_RUN_TILT
		elseif currentWallSide == "Left" then
			targetTilt = -WALL_RUN_TILT
		end
	end
	
	currentTilt += (targetTilt - currentTilt) * 0.12

	-- Movement Sway (Only happens while on solid ground)
	if speed > 2 and Humanoid.FloorMaterial ~= Enum.Material.Air then
		swayTime += dt * SWAY_SPEED * (speed / 16)

		local swayX = math.sin(swayTime) * SWAY_AMOUNT
		local swayY = math.abs(math.cos(swayTime)) * SWAY_AMOUNT

		Camera.CFrame *= CFrame.new(swayX, swayY, 0)
	end

	-- Camera Roll Matrix Multiplication
	Camera.CFrame *= CFrame.Angles(
		0,
		0,
		math.rad(currentTilt)
	)
end)
