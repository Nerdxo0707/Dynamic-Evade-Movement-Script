-- --- THE MAIN CHARACTER ENTERS THE CHAT ("Skitx" Pop-up) ---
local function runStartupSequence()
	local startupGui = Instance.new("ScreenGui")
	startupGui.Name = "SkitxStartupGui"
	startupGui.ResetOnSpawn = false
	startupGui.Parent = playerGui

	local startupLabel = Instance.new("TextLabel")
	startupLabel.Size = UDim2.new(1, 0, 0.1, 0)
	startupLabel.Position = UDim2.new(0, 0, 0.45, 0) -- dead center
	startupLabel.BackgroundTransparency = 1
	startupLabel.Text = "Skitx"
	startupLabel.TextColor3 = Color3.new(1, 1, 1)
	startupLabel.Font = Enum.Font.Arimo
	startupLabel.TextSize = 36
	startupLabel.TextTransparency = 1
	startupLabel.Parent = startupGui

	-- Apply the exact same text gradient to the startup title
	local titleGrad = Instance.new("UIGradient")
	titleGrad.Color = textGradientSequence
	titleGrad.Rotation = 90
	titleGrad.Parent = startupLabel

	local tweenInfoIn = TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local tweenInfoOut = TweenInfo.new(0.7, Enum.EasingStyle.Quad, Enum.EasingDirection.In)

	local fadeIn = TweenService:Create(startupLabel, tweenInfoIn, { TextTransparency = 0 })
	local fadeOut = TweenService:Create(startupLabel, tweenInfoOut, { TextTransparency = 1 })

	fadeIn:Play()
	fadeIn.Completed:Connect(function()
		task.wait(1.2)
		fadeOut:Play()
		fadeOut.Completed:Connect(function()
			startupGui:Destroy()
		end)
	end)
end

runStartupSequence()
