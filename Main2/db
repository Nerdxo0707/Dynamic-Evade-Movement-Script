-- LocalScript inside StarterPlayer > StarterPlayerScripts

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local camera = workspace.CurrentCamera

local character
local humanoid
local rootPart
local playerGui = player:WaitForChild("PlayerGui")

-- MOVEMENT CONFIGS (DO NOT TOUCH UNLESS YOU KNOW SMTH)
local WALL_RUN_SPEED = 50        
local WALL_JUMP_POWER = 90      
local WALL_CHECK_DISTANCE = 4    
local MAX_WALL_RUN_TIME = 2.5
local ACCELERATION = 2.5

-- CINEMATIC
local CAMERA_TILT = 14            
local CAMERA_SMOOTHNESS = 8       
local BASE_FOV = 75
local MAX_FOV = 90
local FOV_SMOOTHNESS = 5          

-- STATE VARIABLES (LET THEM COOK)
local wallRunning = false
local wallRunStart = 0
local currentWallNormal = nil
local currentWallSide = nil

local currentSpeed = 0
local targetTilt = 0
local currentTilt = 0
local cameraRoll = 0              

local wallJumping = false
local wallJumpCooldown = false
local jumpingConnection = nil

-- ShakeS
local shakeIntensity = 0
local shakeDecay = 12

local function runStartupSequence()
	local startupGui = Instance.new("ScreenGui")
	startupGui.Name = "SkitxStartupGui"
	startupGui.ResetOnSpawn = false
	startupGui.Parent = playerGui

	local startupLabel = Instance.new("TextLabel")
	startupLabel.Size = UDim2.new(1, 0, 0.1, 0)
	startupLabel.Position = UDim2.new(0, 0, 0.45, 0) -- dead center, built different
	startupLabel.BackgroundTransparency = 1
	startupLabel.Text = "Skitx"
	startupLabel.TextColor3 = Color3.new(1, 1, 1) -- pure clean white aesthetic
	startupLabel.Font = Enum.Font.Arimo -- Arimo font enjoys standard W
	startupLabel.TextSize = 36
	startupLabel.TextTransparency = 1 -- start invisible, lowkey suspenseful
	startupLabel.Parent = startupGui

	local tweenInfoIn = TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local tweenInfoOut = TweenInfo.new(0.7, Enum.EasingStyle.Quad, Enum.EasingDirection.In)

	
	local fadeIn = TweenService:Create(startupLabel, tweenInfoIn, { TextTransparency = 0 })
	local fadeOut = TweenService:Create(startupLabel, tweenInfoOut, { TextTransparency = 1 })

	fadeIn:Play()
	fadeIn.Completed:Connect(function()
		task.wait(1.2) -- letting it sit there so they see who made it
		fadeOut:Play()
		fadeOut.Completed:Connect(function()
			startupGui:Destroy() -- delete from existence, tidy code fr
		end)
	end)
end


runStartupSequence()
-- -------------------------------------


local function applyCameraShake(intensity)
	shakeIntensity = math.clamp(shakeIntensity + intensity, 0, 0.6)
end

local function setupCharacter(char)
	character = char
	humanoid = char:WaitForChild("Humanoid")
	rootPart = char:WaitForChild("HumanoidRootPart")

	camera.FieldOfView = BASE_FOV
	humanoid.CameraOffset = Vector3.zero

	wallRunning = false
	wallJumping = false
	currentSpeed = 0
	currentTilt = 0
	targetTilt = 0
	cameraRoll = 0

	if jumpingConnection then
		jumpingConnection:Disconnect()
	end

	-- Ground / Bhop Detection (Just the physics shake since text got deleted)
	jumpingConnection = humanoid.Jumping:Connect(function(isActive)
		if isActive and not wallRunning and not wallJumping then
			applyCameraShake(0.2) -- sharp pop for that perfect bhop timing
		end
	end)
	
	-- landing heavy on the concrete shake effect
	humanoid.StateChanged:Connect(function(oldState, newState)
		if newState == Enum.HumanoidStateType.Landed then
			applyCameraShake(0.35) -- boom, landing impact hit hard
		end
	end)
end

setupCharacter(player.Character or player.CharacterAdded:Wait())
player.CharacterAdded:Connect(setupCharacter)

local function getWall()
	if not rootPart then
		return nil
	end

	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.FilterDescendantsInstances = {character}

	-- raycasting right to check if a wall is nearby
	local rightRay = workspace:Raycast(rootPart.Position, rootPart.CFrame.RightVector * WALL_CHECK_DISTANCE, params)
	if rightRay then return rightRay, "Right" end

	-- raycasting left because equality matters
	local leftRay = workspace:Raycast(rootPart.Position, -rootPart.CFrame.RightVector * WALL_CHECK_DISTANCE, params)
	if leftRay then return leftRay, "Left" end

	return nil
end

local function stopWallRun()
	wallRunning = false
	currentWallNormal = nil
	currentWallSide = nil
	targetTilt = 0
end

local function startWallRun(hit, side)
	if wallRunning or wallJumping then
		return
	end

	wallRunning = true
	wallRunStart = tick()
	currentWallNormal = hit.Normal
	currentWallSide = side
	currentSpeed = math.max(currentSpeed, 15)
	
	applyCameraShake(0.25) -- screen shake when you lock onto the geometry
end

UserInputService.JumpRequest:Connect(function()
	if not wallRunning or wallJumpCooldown or not currentWallNormal or not rootPart then
		return -- can't jump if you aren't even on a wall, clear skill issue
	end

	wallJumpCooldown = true
	wallJumping = true

	applyCameraShake(0.4) -- mega screen rattle for the massive leap

	-- math equations doing backflips to calculate the eject trajectory
	local jumpVelocity = (currentWallNormal * WALL_JUMP_POWER) + Vector3.new(0, 55, 0)
	rootPart.AssemblyLinearVelocity = jumpVelocity

	stopWallRun()

	task.delay(0.3, function() wallJumping = false end)
	task.delay(0.25, function() wallJumpCooldown = false end)
end)

RunService.Heartbeat:Connect(function(dt)
	if not humanoid or not rootPart then
		return
	end

	-- checking if bro is airborne and trying to parkour
	if not wallJumping and humanoid.FloorMaterial == Enum.Material.Air then
		local wall, side = getWall()
		if wall then
			if not wallRunning then startWallRun(wall, side) else currentWallNormal = wall.Normal; currentWallSide = side end
		else
			stopWallRun()
		end
	else
		if not wallJumping then stopWallRun() end
	end

	if wallRunning then
		if tick() - wallRunStart > MAX_WALL_RUN_TIME then
			stopWallRun() -- user stayed on the wall too long, fell off + ratio
			return
		end

		-- cross vectors logic (don't worry about it, it just works)
		local wallDirection = currentWallNormal:Cross(Vector3.new(0, 1, 0))
		local moveDir = humanoid.MoveDirection

		if moveDir.Magnitude > 0 and moveDir:Dot(wallDirection) < 0 then
			wallDirection = -wallDirection
		end

		currentSpeed = math.min(currentSpeed + (ACCELERATION * 60 * dt), WALL_RUN_SPEED)
		local currentVelocity = rootPart.AssemblyLinearVelocity

		-- setting the vector3 velocity straight to make them slide smooth
		rootPart.AssemblyLinearVelocity = Vector3.new(
			wallDirection.X * currentSpeed,
			math.max(currentVelocity.Y, -2), -- gravity deceleration fake friction
			wallDirection.Z * currentSpeed
		)

		targetTilt = (currentWallSide == "Right") and CAMERA_TILT or -CAMERA_TILT
	else
		currentSpeed *= 0.96 -- speed drop-off is real
		targetTilt = 0
	end
end)

-- --- THE CINEMATIC RENDER LOOP (VISUAL MASTERPIECE) ---
RunService.RenderStepped:Connect(function(dt)
	if not humanoid or not rootPart then
		return
	end

	local velocity = rootPart.AssemblyLinearVelocity
	local horizontalVelocity = Vector3.new(velocity.X, 0, velocity.Z)
	local speed = horizontalVelocity.Magnitude

	-- 1. Momentum Banking (Tilting the camera when strafing mid-air, very clean)
	local relativeMove = rootPart.CFrame:VectorToObjectSpace(horizontalVelocity)
	local strafeTarget = -relativeMove.X * 0.18
	cameraRoll = cameraRoll + (strafeTarget - cameraRoll) * math.clamp(dt * 6, 0, 1)

	-- 2. Wall run camera tilt interpolation
	currentTilt = currentTilt + (targetTilt - currentTilt) * math.clamp(dt * CAMERA_SMOOTHNESS, 0, 1)

	-- 3. Layered Headbob (Simulating steps so the camera isn't stiff as a board)
	local bobX = 0
	local bobY = 0
	
	if speed > 1 then
		if wallRunning then
			bobY = math.sin(time() * 14) * 0.06 -- quick head bob while wall running
			bobX = math.cos(time() * 7) * 0.03
		elseif humanoid.FloorMaterial ~= Enum.Material.Air then
			-- regular running headbob scaled by your current velocity magnitude
			local bobMultiplier = math.clamp(speed / WALL_RUN_SPEED, 0.2, 1)
			bobY = math.sin(time() * 12) * (0.04 * bobMultiplier)
			bobX = math.cos(time() * 6) * (0.02 * bobMultiplier)
		end
	end

	-- 4. Handshake mathematics calculating camera trauma/shaking
	if shakeIntensity > 0 then
		shakeIntensity = math.max(0, shakeIntensity - (dt * shakeDecay))
	end
	local appliedShakeX = (math.random(-100, 100) / 100) * shakeIntensity * 0.15
	local appliedShakeY = (math.random(-100, 100) / 100) * shakeIntensity * 0.15

	-- Inject offsets straight into the Roblox camera core system
	humanoid.CameraOffset = Vector3.new(
		(currentTilt * 0.035) + bobX + appliedShakeX, 
		bobY + appliedShakeY, 
		0
	)

	-- 5. Combine camera tilt, keyboard lean, and impact vibration into the CFrame matrix
	local finalRoll = currentTilt + cameraRoll + (appliedShakeX * 15)
	camera.CFrame = camera.CFrame * CFrame.Angles(0, 0, math.rad(finalRoll))

	-- 6. Dynamic Field Of View changes based on speed (feels fast af)
	local targetFOV = BASE_FOV
	if wallRunning then
		targetFOV = MAX_FOV
	else
		targetFOV = BASE_FOV + math.clamp(speed / 4, 0, (MAX_FOV - BASE_FOV))
	end

	camera.FieldOfView = camera.FieldOfView + (targetFOV - camera.FieldOfView) * math.clamp(dt * FOV_SMOOTHNESS, 0, 1)
end)
